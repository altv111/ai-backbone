AI_BACKBONE_APP_NAME=ai-backbone
AI_BACKBONE_ENVIRONMENT=dev
AI_BACKBONE_DEBUG=false
AI_BACKBONE_MAX_MESSAGES=50
AI_BACKBONE_MAX_TEXTS_PER_EMBED=100
AI_BACKBONE_MAX_DOCUMENTS_PER_INDEX=100
AI_BACKBONE_MAX_TOP_K=50
AI_BACKBONE_ENABLE_MOCK_PROVIDERS=true
AI_BACKBONE_AUDIT_ENABLED=true
AI_BACKBONE_AUDIT_LOG_PATH=

# Central LLM
CENTRAL_LLM_ENABLED=false
CENTRAL_LLM_API_URL=
CENTRAL_LLM_API_KEY=
CENTRAL_LLM_TIMEOUT_SECONDS=60
CENTRAL_LLM_DEFAULT_MODEL=gemini-flash
CENTRAL_LLM_ALLOWED_MODELS=gemini-flash,gemini-pro
CENTRAL_LLM_DEFAULT_DATA_CLASSIFICATION=internal
CENTRAL_LLM_VERIFY_SSL=false

# Gemma provider in backbone
GEMMA_ENABLED=false
GEMMA_WORKERS_JSON=[]
GEMMA_TIMEOUT_SECONDS=120
GEMMA_DEFAULT_MODEL=gemma-12b-it
GEMMA_DEFAULT_MAX_NEW_TOKENS=512
GEMMA_DEFAULT_TEMPERATURE=0.2

# FAISS HTTP provider in backbone
FAISS_HTTP_ENABLED=false
FAISS_WORKER_URL=http://localhost:8890
FAISS_HTTP_TIMEOUT_SECONDS=120

# Gemma worker service
GEMMA_WORKER_MODEL_NAME=gemma-12b-it
GEMMA_WORKER_MODEL_PATH=
GEMMA_WORKER_HOST=0.0.0.0
GEMMA_WORKER_PORT=8888
GEMMA_WORKER_MAX_CONCURRENT=1
GEMMA_WORKER_MOCK_MODE=true
GEMMA_WORKER_NUM_THREADS=0
GEMMA_WORKER_NUM_INTEROP_THREADS=0

# FAISS worker service
FAISS_WORKER_HOST=0.0.0.0
FAISS_WORKER_PORT=8890
FAISS_WORKER_INDEX_ROOT=./data/faiss_indexes
FAISS_WORKER_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
FAISS_WORKER_MOCK_MODE=true
FAISS_WORKER_MAX_DOCUMENTS_PER_INDEX=10000
FAISS_WORKER_MAX_TOP_K=50
